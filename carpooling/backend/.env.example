# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# AWS Region
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# RDS (MySQL)
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=3306
DB_NAME=carpooling_db
DB_USER=admin
DB_PASSWORD=your_db_password

# ElastiCache (Redis)
REDIS_HOST=your-elasticache-endpoint.cache.amazonaws.com
REDIS_PORT=6379
REDIS_TTL=300

# AWS Cognito
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=your_cognito_client_id
COGNITO_REGION=us-east-1

# S3
S3_BUCKET_NAME=carpooling-profile-photos
S3_REGION=us-east-1

# SNS
SNS_TOPIC_ARN_BOOKINGS=arn:aws:sns:us-east-1:123456789:carpooling-bookings
SNS_TOPIC_ARN_CANCELLATIONS=arn:aws:sns:us-east-1:123456789:carpooling-cancellations

# JWT
JWT_SECRET=your_jwt_secret_key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
